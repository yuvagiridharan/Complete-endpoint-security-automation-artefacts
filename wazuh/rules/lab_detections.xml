<group name="lab_detections,">

  <!-- Rule 100001: Encoded PowerShell -->
  <rule id="100001" level="12">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)-[eE][nN][cC]</field>
    <description>Encoded PowerShell - T1059.001</description>
    <mitre><id>T1059.001</id></mitre>
  </rule>

  <!-- Rule 100002: Scheduled Task -->
  <rule id="100002" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^4698$</field>
    <description>Scheduled task created - T1053.005</description>
    <mitre><id>T1053.005</id></mitre>
  </rule>

  <!-- Rule 100003: Shadow file read - LOW level no webhook -->
  <rule id="100003" level="3">
    <if_group>audit</if_group>
    <field name="audit.key">shadow_read</field>
    <description>Sensitive file /etc/shadow accessed - T1548.003</description>
    <mitre><id>T1548.003</id></mitre>
  </rule>

  <!-- Rule 100004: Crontab Modified -->
  <rule id="100004" level="10">
    <if_group>audit</if_group>
    <field name="audit.key">cron_changes</field>
    <description>Crontab modified - T1053.003</description>
    <mitre><id>T1053.003</id></mitre>
  </rule>

  <!-- Rule 100005: SSH Login -->
  <rule id="100005" level="3">
    <if_sid>5501</if_sid>
    <description>SSH login success - T1021</description>
    <mitre><id>T1021</id></mitre>
  </rule>

  <!-- Rule 100006: Windows Failed Login -->
  <rule id="100006" level="5">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^4625$</field>
    <description>Windows login failed - T1110</description>
    <mitre><id>T1110</id></mitre>
  </rule>

  <!-- Rule 100007: Windows Brute Force -->
  <rule id="100007" level="10" frequency="3" timeframe="60">
    <if_matched_sid>100006</if_matched_sid>
    <description>Windows brute force - T1110</description>
    <mitre><id>T1110</id></mitre>
  </rule>

  <!-- Rule 100008: Suspicious Process Windows -->
  <rule id="100008" level="12">
    <if_sid>67027</if_sid>
    <field name="win.eventdata.newProcessName" type="pcre2">(?i)(nc\.exe|ncat\.exe|mimikatz)</field>
    <description>Suspicious process - T1059</description>
    <mitre><id>T1059</id></mitre>
  </rule>

  <!-- Rule 100009: Suspicious PowerShell -->
  <rule id="100009" level="12">
    <if_sid>67027</if_sid>
    <field name="win.eventdata.newProcessName" type="pcre2">(?i)powershell\.exe</field>
    <field name="win.eventdata.subjectUserName" type="pcre2">(?i)(testuser|attacker)</field>
    <description>Suspicious PowerShell - T1059.001</description>
    <mitre><id>T1059.001</id></mitre>
  </rule>

  <!-- Rule 100010: CMD by attacker -->
  <rule id="100010" level="10">
    <if_sid>67027</if_sid>
    <field name="win.eventdata.newProcessName" type="pcre2">(?i)cmd\.exe</field>
    <field name="win.eventdata.subjectUserName" type="pcre2">(?i)(testuser|attacker)</field>
    <description>CMD by suspicious user - T1059.003</description>
    <mitre><id>T1059.003</id></mitre>
  </rule>

  <!-- Rule 100011: Sudo execution - LOW level -->
  <rule id="100011" level="3">
    <if_group>audit</if_group>
    <field name="audit.key">sudo_exec</field>
    <description>Sudo command executed - T1548.003</description>
    <mitre><id>T1548.003</id></mitre>
  </rule>

  <!-- Rule 100012: Crontab executed -->
  <rule id="100012" level="10">
    <if_group>audit</if_group>
    <field name="audit.exe">/usr/bin/crontab</field>
    <field name="audit.success">yes</field>
    <description>Crontab executed - T1053.003</description>
    <mitre><id>T1053.003</id></mitre>
  </rule>

</group>
